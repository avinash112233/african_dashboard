# MERRA2 PM2.5 backend – set for real GES DISC data
# Create account: https://urs.earthdata.nasa.gov/

EARTHDATA_USERNAME=your_username
EARTHDATA_PASSWORD=your_password

# FIRMS (Fire Hotspots) – get free key at https://firms.modaps.eosdis.nasa.gov/api/

VITE_FIRMS_MAP_KEY=your_firms_map_key

# Optional: backend port (default 3001)
# MERRA2_API_PORT=3001